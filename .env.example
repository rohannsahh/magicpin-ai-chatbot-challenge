# ─── LLM Provider ───────────────────────────────────────────────────────────
# Choose one: openai | anthropic | gemini | groq | deepseek
LLM_PROVIDER=openai

# Paste your API key here
LLM_API_KEY=sk-...

# Optional: override the default model
# openai default: gpt-4o-mini  (fast, cheap, great quality)
# anthropic default: claude-3-haiku-20240307
# gemini default: gemini-1.5-flash
LLM_MODEL=

# ─── Bot server ──────────────────────────────────────────────────────────────
BOT_PORT=8080
